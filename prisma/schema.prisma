// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  access_token      String? @db.Text
  expires_at        Int?
  id                String  @id @default(cuid())
  id_token          String? @db.Text
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  scope             String?
  session_state     String?
  token_type        String?
  type              String
  userId            String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AIExplanation {
  aiModel   String
  createdAt DateTime @default(now())
  globalId  String   @unique
  id        String   @id @default(cuid())
  paperId   String
  prompt    String   @db.Text
  text      String   @db.Text
  updatedAt DateTime @updatedAt

  @@index([paperId])
  @@map("ai_explanations")
}

model Bookmark {
  category                String?
  createdAt               DateTime @default(now())
  globalId                String
  id                      String   @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  updatedAt               DateTime @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([globalId, userId])
  @@map("bookmarks")
}

model CuratedQuote {
  createdAt DateTime  @default(now())
  globalId  String    @unique
  id        String    @id @default(cuid())
  paperId   String
  sentAt    DateTime?
  updatedAt DateTime  @updatedAt

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@map("curated_quotes")
}

model Note {
  createdAt               DateTime @default(now())
  globalId                String
  id                      String   @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  text                    String
  updatedAt               DateTime @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Paper {
  createdAt DateTime @default(now())
  globalId  String
  id        String   @id
  title     String
  updatedAt DateTime @updatedAt

  curatedQuotes CuratedQuote[]
  paperLabels   PaperLabel[]
  sentQuotes    SentQuote[]

  @@map("papers")
}

model Label {
  createdAt   DateTime @default(now())
  description String
  id          String   @id @default(cuid())
  name        String   @unique
  updatedAt   DateTime @updatedAt

  papers        PaperLabel[]
  userInterests UserInterest[]

  @@map("labels")
}

model PaperLabel {
  createdAt DateTime @default(now())
  paperId   String
  labelId   String
  updatedAt DateTime @updatedAt

  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)
  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@id([paperId, labelId])
  @@map("paper_labels")
}

model ReadNode {
  createdAt               DateTime @default(now())
  globalId                String
  id                      String   @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  updatedAt               DateTime @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("read_nodes")
}

model SentQuote {
  globalId String
  id       String   @id @default(cuid())
  paperId  String
  sentAt   DateTime @default(now())
  userId   String

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, globalId])
  @@map("sent_quotes")
}

model Session {
  expires      DateTime
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum SharePlatform {
  COPY_LINK
  COPY_TEXT
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  X
}

model Share {
  count                   Int
  createdAt               DateTime      @default(now())
  globalId                String
  id                      String        @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  platform                SharePlatform
  updatedAt               DateTime      @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shares")
}

model User {
  createdAt                   DateTime  @default(now())
  email                       String?   @unique
  emailNotificationsEnabled   Boolean?  @default(true)
  emailDailyQuoteEnabled      Boolean?  @default(true)
  emailContinueReadingEnabled Boolean?  @default(true)
  emailChangelogEnabled       Boolean?  @default(true)
  emailVerified               DateTime?
  id                          String    @id @default(cuid())
  image                       String?
  isAdmin                     Boolean   @default(false)
  lastAskedNotificationsAt    DateTime?
  lastVisitedAt               DateTime?
  lastVisitedGlobalId         String?
  lastVisitedPaperId          String?
  lastVisitedPaperTitle       String?
  name                        String?
  updatedAt                   DateTime  @updatedAt

  accounts      Account[]
  bookmarks     Bookmark[]
  notes         Note[]
  readNodes     ReadNode[]
  sentQuotes    SentQuote[]
  sessions      Session[]
  shares        Share[]
  userInterests UserInterest[]

  @@map("users")
}

model UserInterest {
  createdAt DateTime @default(now())
  labelId   String
  updatedAt DateTime @updatedAt
  userId    String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([userId, labelId])
  @@map("user_interests")
}

model VerificationToken {
  expires    DateTime
  identifier String
  token      String   @unique

  @@unique([identifier, token])
  @@map("verification_tokens")
}
