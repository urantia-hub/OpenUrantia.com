// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  access_token      String? @db.Text
  expires_at        Int?
  id                String  @id @default(cuid())
  id_token          String? @db.Text
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  scope             String?
  session_state     String?
  token_type        String?
  type              String
  userId            String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model NodeComment {
  createdAt               DateTime @default(now())
  globalId                String
  id                      String   @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  text                    String
  updatedAt               DateTime @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("node_comments")
}

model NodeReference {
  authors                 String[]
  createdAt               DateTime  @default(now())
  description             String?
  globalId                String
  id                      String    @id @default(cuid())
  link                    String?
  page                    String?
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  publishedAt             DateTime?
  title                   String?
  updatedAt               DateTime  @updatedAt

  @@map("node_references")
}

model SavedNode {
  createdAt               DateTime @default(now())
  globalId                String
  id                      String   @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  updatedAt               DateTime @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([globalId, userId])
  @@map("saved_nodes")
}

model Session {
  expires      DateTime
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum SharedNodePlatform {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  X
}

model SharedNode {
  count                   Int
  createdAt               DateTime           @default(now())
  globalId                String
  id                      String             @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  platform                SharedNodePlatform
  updatedAt               DateTime           @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shared_nodes")
}

model User {
  createdAt     DateTime  @default(now())
  email         String?   @unique
  emailVerified Boolean?
  id            String    @id @default(cuid())
  image         String?
  name          String?
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  nodeComments NodeComment[]
  savedNodes   SavedNode[]
  sessions     Session[]
  shareNodes   SharedNode[]

  @@map("users")
}

model VerificationToken {
  expires    DateTime
  identifier String
  token      String   @unique

  @@unique([identifier, token])
  @@map("verification_tokens")
}
