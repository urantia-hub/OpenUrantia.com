// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  access_token      String? @db.Text
  expires_at        Int?
  id                String  @id @default(cuid())
  id_token          String? @db.Text
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  scope             String?
  session_state     String?
  token_type        String?
  type              String
  userId            String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])

  @@map("accounts")
}

model Bookmark {
  createdAt               DateTime @default(now())
  globalId                String
  id                      String   @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  updatedAt               DateTime @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([globalId, userId])

  @@map("bookmarks")
}

model Note {
  createdAt               DateTime @default(now())
  globalId                String
  id                      String   @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  text                    String
  updatedAt               DateTime @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model ReadNode {
  createdAt               DateTime @default(now())
  globalId                String
  id                      String   @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  updatedAt               DateTime @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("read_nodes")
}

model Session {
  expires      DateTime
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum SharePlatform {
  COPY_LINK
  COPY_TEXT
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  X
}

model Share {
  count                   Int
  createdAt               DateTime      @default(now())
  globalId                String
  id                      String        @id @default(cuid())
  paperId                 String
  paperSectionId          String
  paperSectionParagraphId String
  platform                SharePlatform
  updatedAt               DateTime      @updatedAt
  userId                  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shares")
}

model User {
  createdAt                 DateTime  @default(now())
  email                     String?   @unique
  emailVerified             Boolean?
  id                        String    @id @default(cuid())
  image                     String?
  lastAskedNotificationsAt  DateTime?
  lastVisitedAt             DateTime?
  lastVisitedGlobalId       String?
  lastVisitedPaperId        String?
  lastVisitedPaperTitle     String?
  name                      String?
  emailNotificationsEnabled Boolean?  @default(false)
  updatedAt                 DateTime  @updatedAt

  accounts  Account[]
  bookmarks Bookmark[]
  notes     Note[]
  readNodes ReadNode[]
  sessions  Session[]
  shares    Share[]

  @@map("users")
}

model VerificationToken {
  expires    DateTime
  identifier String
  token      String   @unique

  @@unique([identifier, token])

  @@map("verification_tokens")
}
